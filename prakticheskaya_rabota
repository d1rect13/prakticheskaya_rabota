// ==============================================================================
// ЗАДАНИЕ 20: Удаление максимального элемента со сдвигом
// ==============================================================================

// 1. По значению: n передается как копия. Изменения n внутри функции не меняют n в main.
// Возвращаем измененный размер через return.
int F20_val(int A[], int n) {
    int i, k = 0, j;
    // Поиск индекса максимального элемента
    for (i = 1; i < n; i++)
        if (A[i] > A[k]) k = i; // k запоминает индекс максимума
    // Сдвигаем элементы влево, затирая максимум
    for (j = k; j < n - 1; j++) A[j] = A[j + 1];
    n--;
    return n; // Возвращаем новый размер
}

// 2. По ссылке: &n означает, что мы работаем с оригинальной переменной под другим именем.
void F20_ref(int A[], int& n) {
    int i, k = 0, j;
    for (i = 1; i < n; i++)
        if (A[i] > A[k]) k = i;
    for (j = k; j < n - 1; j++) A[j] = A[j + 1];
    n--; // Уменьшаем размер прямо в оригинальной переменной в main
}

// 3. По указателю: *n означает, что мы получили адрес переменной и работаем через разыменование.
void F20_pointer(int A[], int* n) {
    int i, k = 0, j;
    // Используем (*n), чтобы достать значение, лежащее по этому адресу
    for (i = 1; i < *n; i++)
        if (A[i] > A[k]) k = i;
    for (j = k; j < *n - 1; j++) A[j] = A[j + 1];
    (*n)--; // Изменяем значение в ячейке памяти напрямую
}

// ==============================================================================
// ЗАДАНИЕ 29: Поиск наибольшего общего делителя (НОД) массива
// ==============================================================================

// 1. По значению: работаем с копией переменной v
int F29_val(int A[], int n, int v) {
    int i;
    for (i = 0; i < n; i++)
        if (A[i] % v != 0) {
            v--;    // Уменьшаем наш делитель
            i = -1; // Начинаем проверку массива заново (после i++ счетчик станет 0)
        }
    return v;
}

// 2. По ссылке: меняем v в main напрямую через псевдоним &v
void F29_ref(int A[], int n, int& v) {
    int i;
    for (i = 0; i < n; i++)
        if (A[i] % v != 0) { v--; i = -1; }
}

// 3. По указателю: получаем адрес v и меняем значение через *v
void F29_pointer(int A[], int n, int* v) {
    int i;
    for (i = 0; i < n; i++)
        if (A[i] % (*v) != 0) { (*v)--; i = -1; }
}

// ==============================================================================
// ЗАДАНИЕ 37: Поиск индекса самого часто встречающегося элемента
// ==============================================================================

// 1. По значению: возвращаем индекс через return
int F37_val(int c[], int n) {
    int s = 0, i, j, m = 0, b = 0;
    for (i = 0; i < n - 1; i++) {
        for (j = i + 1, m = 0; j < n; j++)
            if (c[i] == c[j]) m++; // m — счетчик повторений текущего элемента
        if (m > s) { s = m; b = i; } // s хранит максимальное число повторов, b — его индекс
    }
    return b;
}

// 2. По ссылке: записываем результат в b напрямую
void F37_ref(int c[], int n, int& b) {
    int s = 0, i, j, m = 0;
    b = 0;
    for (i = 0; i < n - 1; i++) {
        for (j = i + 1, m = 0; j < n; j++)
            if (c[i] == c[j]) m++;
        if (m > s) { s = m; b = i; }
    }
}

// 3. По указателю: записываем результат по адресу переменной b
void F37_pointer(int c[], int n, int* b) {
    int s = 0, i, j, m = 0;
    *b = 0;
    for (i = 0; i < n - 1; i++) {
        for (j = i + 1, m = 0; j < n; j++)
            if (c[i] == c[j]) m++;
        if (m > s) { s = m; *b = i; }
    }
}

// ==============================================================================
// ЗАДАНИЕ 48: Удаление соседних одинаковых элементов (пар)
// ==============================================================================

// 1. По значению: возвращаем новый размер n
int F48_val(int A[], int n) {
    int i, j;
    for (i = 0; i < n - 1; i++)
        if (A[i] == A[i + 1]) { // Если нашли дубликаты по соседству
            for (j = i; j < n - 2; j++) A[j] = A[j + 2]; // Сдвигаем всё влево на 2 позиции
            n = n - 2; // Уменьшаем размер на 2 элемента
            i--;       // Шаг назад, чтобы проверить новые элементы на этом месте
        }
    return n;
}

// 2. По ссылке: меняем размер в main напрямую
void F48_ref(int A[], int& n) {
    int i, j;
    for (i = 0; i < n - 1; i++)
        if (A[i] == A[i + 1]) {
            for (j = i; j < n - 2; j++) A[j] = A[j + 2];
            n = n - 2;
            i--;
        }
}

// 3. По указателю: меняем размер по адресу переменной
void F48_pointer(int A[], int* n) {
    int i, j;
    for (i = 0; i < *n - 1; i++)
        if (A[i] == A[i + 1]) {
            for (j = i; j < *n - 2; j++) A[j] = A[j + 2];
            *n = *n - 2;
            i--;
        }
}

// ==============================================================================
// ЗАДАНИЕ 57: Максимальная длина строго возрастающей последовательности
// ==============================================================================

// 1. По значению: возвращаем длину возрастания
int F57_val(int A[]) {
    int i, s = 0, k = 0;
    for (i = 1; i < 10; i++) {
        if (A[i - 1] < A[i]) k++; // Если текущий элемент больше предыдущего, длина растет
        else {
            if (k > s) s = k; // Обновляем глобальный максимум длины
            k = 0;            // Сбрасываем текущий счетчик
        }
    }
    if (k > s) s = k; // Проверка на случай, если массив возрастал до самого конца
    return s;
}

// 2. По ссылке: пишем результат в переменную s напрямую
void F57_ref(int A[], int& s) {
    int i, k = 0;
    s = 0;
    for (i = 1; i < 10; i++) {
        if (A[i - 1] < A[i]) k++;
        else {
            if (k > s) s = k;
            k = 0;
        }
    }
    if (k > s) s = k;
}

// 3. По указателю: пишем результат по адресу переменной s
void F57_pointer(int A[], int* s) {
    int i, k = 0;
    *s = 0;
    for (i = 1; i < 10; i++) {
        if (A[i - 1] < A[i]) k++;
        else {
            if (k > *s) *s = k;
            k = 0;
        }
    }
    if (k > *s) *s = k;
}

